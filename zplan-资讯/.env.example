# 相对路径会解析到 ZPLAN_ROOT（zplan-资讯/）下的 zplan.db
DB_URL=sqlite:///zplan.db
# 也可不写 DB_URL，默认即 {ZPLAN_ROOT}/zplan.db 的绝对路径
# 大容量/生产：PostgreSQL（需 pip 安装 psycopg，并 docker compose -f docker-compose.postgres.yml up -d）
# DB_URL=postgresql+psycopg://zplan:zplan@127.0.0.1:5432/zplan
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=15
# 股价 Agent 每日定时（LaunchAgent，仅工作日）
DAILY_PRICES_CRON_EVENING=17:35
DAILY_PRICES_CRON_MORNING=08:05
DAILY_PRICES_RUN_SNAPSHOT=true
# true=每日财报 ETL；weekly=仅周五；false=不跑
DAILY_PRICES_RUN_FINANCIAL=weekly
DAILY_PRICES_RUN_INTRADAY=false
DAILY_PRICES_TRIGGER_PICK=true
PICK_PIPELINE_TOP=300
AKSHARE_RATE_LIMIT_SECONDS=2
AKSHARE_FAIL_CIRCUIT_THRESHOLD=3
AKSHARE_FAIL_CIRCUIT_SLEEP_SECONDS=20
NEWS_SCHEDULE_HOURS=4
NEWS_FETCH_LIMIT_PER_TOPIC=10
NEWS_WINDOW_HOURS=2
# 企业微信机器人 Webhook（群聊 → 添加机器人 → 复制地址，仅推送）
WECHAT_PUSH_WEBHOOK=
# 是否记录企微对话历史到 chat_history 表（用于回复质量审计，默认 true）
CHAT_HISTORY_ENABLED=true
# OpenClaw 企微智能机器人（API 模式 · 长连接）→ ./scripts/sync_openclaw_wecom.sh
WECOM_BOT_ID=
WECOM_BOT_SECRET=
# OpenClaw 收到消息后由 Agent 调：python openclaw_bridge.py wechat-reply --text "…"
WECHAT_PUSH_MODE=markdown
WECHAT_PUSH_DIGEST=true
# 群推送样式：brief=资讯简报（默认）；debug=全源 ETL 调试样例
SENTIMENT_WECHAT_STYLE=brief
SENTIMENT_WECHAT_DIGEST_LLM=true
# 可选：HTTP 桥鉴权（python openclaw_bridge.py wechat-serve）
# WECHAT_HTTP_TOKEN=
# 企业微信应用双向问答（与群机器人 webhook 不同，需在管理后台创建自建应用）
# 设置步骤：见 scripts/tunnel_callback.sh 头部注释
# WECHAT_CORP_ID=ww1234567890abcdef
# WECHAT_CORP_SECRET=你的应用 Secret
# WECHAT_AGENT_ID=1000002
# WECHAT_CALLBACK_TOKEN=随机10位字符串
# WECHAT_CALLBACK_AES_KEY=随机43位字符串
# 回调 URL：https://<公网>/v1/wework/callback
# 本地服务：python openclaw_bridge.py wechat-serve --host 127.0.0.1 --port 8765
# 公网隧道：./scripts/tunnel_callback.sh start
# 会话窗口（@一次后多久内无需再@，默认 120 分钟）
# CHAT_SESSION_TTL_MINUTES=120
# DeepSeek API（Chat Completions，OpenAI 兼容）
# 业务 LLM：选股研报 / 新闻摘要 / 资讯问答
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# 默认即可；若用第三方端点可覆盖
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
# LLM 控制
# false=不调用 LLM，仅用规则摘录
LLM_SUMMARY_ENABLED=true
# 任意两次 LLM HTTP 最小间隔（秒，含重试）
DEEPSEEK_MIN_SECONDS_BETWEEN_CALLS=1.5
# max_tokens 上限
DEEPSEEK_MAX_OUTPUT_TOKENS=8192
# 请求超时（秒）
DEEPSEEK_TIMEOUT_SECONDS=90

# 以下 Gemini 变量保留向后兼容（过渡期），底层已切换 DeepSeek
# 若同时配置了 DEEPSEEK_API_KEY 和 GEMINI_API_KEY，优先使用前者
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_SUMMARY_MAX_ITEMS=15
GEMINI_SUMMARY_CHARS_PER_ITEM=900
GEMINI_MIN_SECONDS_BETWEEN_TOPICS=8
GEMINI_MIN_SECONDS_BETWEEN_CALLS=3
GEMINI_MAX_OUTPUT_TOKENS=4096
# 追加到所有 X 查询末尾的排除词（留空则用内置：-telegram -t.me -forex …）
X_QUERY_EXCLUDE_SUFFIX=
X_API_BASE_URL=https://api.twitter.com/2
X_BEARER_TOKEN=
X_HTTP_TIMEOUT_SECONDS=20
X_MAX_RESULTS_PER_PAGE=10
X_MAX_PAGES_PER_TOPIC=1
# false=不拉 @用户名，省 User 读费用（$0.010/个）
X_FETCH_USERNAMES=false
X_RATE_LIMIT_SLEEP_SECONDS=60
X_FAILOVER_TO_PLACEHOLDER=true
HTTPS_PROXY=
HTTP_PROXY=
# macOS 系统代理（Wi‑Fi → 代理）：默认自动读取 scutil，无需手填 HTTP_PROXY
USE_SYSTEM_PROXY=true
# PAC（谢公屐等）：无 env/系统端口代理时由 pypac 执行 PAC JS
PAC_URL=
USE_PYPAC=true
PAC_FROM_SYSTEM=true
